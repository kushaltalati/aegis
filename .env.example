# Copy to .env and fill in. The app runs without an AI key (local fallback engine).
# PostgreSQL connection string. For production use a free Neon DB (https://neon.tech)
# and paste its POOLED connection string here (and into Vercel's env vars).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Free key from https://aistudio.google.com/apikey — enables context-aware AI classification.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
GEMINI_API_BASE="https://generativelanguage.googleapis.com/v1beta"
# Retries per model on transient failures (429 rate-limit / 5xx / network) before
# trying the next model in the fallback chain, then the local engine. Default: 2.
GEMINI_MAX_RETRIES="2"

# Secondary AI fallback (used when Gemini fails, BEFORE the local engine).
# Defaults to Groq — a FREE, fast, OpenAI-compatible API. Get a key:
# https://console.groq.com/keys   (works with any OpenAI-compatible endpoint)
FALLBACK_LLM_API_KEY=""
FALLBACK_LLM_BASE_URL="https://api.groq.com/openai/v1"
FALLBACK_LLM_MODEL="llama-3.3-70b-versatile"
FALLBACK_LLM_MAX_RETRIES="2"

# auto | gemini | local  (auto honours each platform's policy, falls back to local)
MODERATION_ENGINE="auto"
